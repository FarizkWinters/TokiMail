# ============================================================
# TOKIMAIL — Environment Variables
# Salin file ini ke .env dan isi nilainya
# ============================================================

# ------------------------------------------------------------
# BRANDING (opsional — bisa dikustomisasi per penyewa)
# ------------------------------------------------------------

# Nama brand yang muncul di seluruh UI
APP_NAME=TokiMail

# Tagline/subtitle di halaman docs dan keys
APP_TAGLINE=Disposable email. Instant. Private.

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# PostgreSQL connection string
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://postgres:password@localhost:5432/tokimail

# ------------------------------------------------------------
# DOMAIN & EMAIL ROUTING
# ------------------------------------------------------------

# Domain fallback jika tidak pakai Cloudflare API
# (digunakan jika CLOUDFLARE_API_TOKEN dan ALLOWED_DOMAINS tidak diset)
MAIL_DOMAIN=mail.contoh.com

# Domain yang diizinkan — pisah dengan koma (tanpa spasi)
# Jika diset, hanya domain ini yang muncul di dropdown
# Jika tidak diset + ada CF token, semua domain Cloudflare akan ditampilkan
ALLOWED_DOMAINS=mail.contoh.com,inbox.contoh.com

# Cloudflare API Token (untuk fetch daftar domain otomatis)
# Buat di: https://dash.cloudflare.com/profile/api-tokens
# Permission yang dibutuhkan: Zone:Read
# Bisa dikosongkan jika pakai ALLOWED_DOMAINS manual
CLOUDFLARE_API_TOKEN=

# ------------------------------------------------------------
# KEAMANAN
# ------------------------------------------------------------

# Secret untuk verifikasi email masuk dari Cloudflare Worker
# Harus SAMA PERSIS dengan WEBHOOK_SECRET di Cloudflare Worker
# Generate contoh: openssl rand -hex 32
WEBHOOK_SECRET=ganti_dengan_string_acak_yang_panjang

# Password untuk mengakses halaman Admin (/admin)
# Berisi: API Keys manager & Dokumentasi API
# Jika tidak diset, halaman admin tidak bisa diakses
ADMIN_PASSWORD=ganti_dengan_password_admin

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------

# Port untuk API server (default otomatis dari environment)
PORT=8080

# Node environment
NODE_ENV=production
